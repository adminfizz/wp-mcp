# Telegram (ใช้ token แยกจาก slip-bot)
TELEGRAM_BOT_TOKEN=

# Claude (เขียนบทความ + ตีความคำสั่งภาษาไทย)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# Gemini (สร้างรูปจากเนื้อหา) — ใช้ key เดียวกับ slip-bot ได้
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# จำกัดสิทธิ์ผู้สั่ง (chat id คั่นด้วย comma) — ว่าง = อนุญาตทุกคน (ไม่แนะนำ)
ALLOWED_CHAT_IDS=

# ตำแหน่งจุดเข้า MCP server (ชั้น 2)
MCP_SERVER_ENTRY=../mcp-server/src/index.js
# ส่งต่อให้ MCP server: ตำแหน่งไฟล์ทะเบียนโดเมน
DOMAINS_FILE=../mcp-server/config/domains.json
